# xAI config.
# Override order: .env < .env.<profile> < shell.

# Bearer token from console.x.ai. Required.
XAI_API_KEY=

# Optional: override the API root. Default https://api.x.ai/v1.
# XAI_BASE_URL=

# Optional: override context size when xAI's /v1/language-models doesn't
# resolve the model alias (rare; new model not yet in the per-family table
# shipped with this sibling). The catch-all is more pragmatic than throwing.
# XAI_CONTEXT_SIZE=

# Note: fetch timeout is the universal PLURNK_PROVIDER_FETCH_TIMEOUT
# (set in plurnk-service's env). Reasoning is the universal PLURNK_REASON;
# this sibling translates numeric budget into xAI's reasoning_effort tier
# (none|low|medium|high). See README for breakpoints.
